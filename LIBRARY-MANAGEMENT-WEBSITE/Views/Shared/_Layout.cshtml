<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Library Management</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("Library Management", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })

            <button type="button" class="navbar-toggler" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Books", "Index", "Book", null, new { @class = "nav-link" })
                    </li>

                    @* --- ADMIN ONLY LINKS DROPDOWN (Fixed for Modern Bootstrap) --- *@
                    @if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                    {
                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" id="adminDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                Admin Panel
                            </a>
                            <div class="dropdown-menu" aria-labelledby="adminDropdown">
                                @Html.ActionLink("Dashboard", "Dashboard", "Admin", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Manage Books", "ManageBooks", "Admin", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Add New Book", "AddBook", "Admin", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Manage Categories", "ManageCategories", "Admin", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Manage Readers", "ManageReaders", "Admin", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Manage Borrowings", "ManageBorrowings", "Admin", null, new { @class = "dropdown-item" })
                            </div>
                        </li>
                    }

                    @* --- LIBRARIAN ONLY LINKS --- *@
                    @if (Session["UserId"] != null && Session["Role"] != null && Session["Role"].ToString() == "Librarian")
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Dashboard", "Index", "Librarian", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (Session["UserId"] != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link" style="color: #fff !important; font-weight: bold; padding-right: 15px;">Hello, @Session["FullName"]</span>
                        </li>

                        if (Session["Role"] != null && Session["Role"].ToString() == "Librarian")
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Librarian Profile", "Profile", "Librarian", null, new { @class = "nav-link" })
                            </li>
                        }
                        else if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                        {
                            // Admin profiles loop back cleanly or point directly to dashboard actions
                            <li class="nav-item">
                                @Html.ActionLink("Admin Center", "Dashboard", "Admin", null, new { @class = "nav-link" })
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                @Html.ActionLink("My Profile", "Profile", "Reader", null, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("My Borrowings", "MyBorrowings", "Borrowing", null, new { @class = "nav-link" })
                            </li>
                        }

                        <li class="nav-item">
                            @Html.ActionLink("Logout", "Logout", "Account", null, new { @class = "nav-link", style = "color: #ffc107 !important;" })
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Login", "Login", "Account", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Register", "Register", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content" style="margin-top: 25px; min-height: 75vh;">
        @RenderBody()

        <hr style="margin-top: 40px;" />

        <footer>
            <p>&copy; @DateTime.Now.Year - Library Management Website</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>