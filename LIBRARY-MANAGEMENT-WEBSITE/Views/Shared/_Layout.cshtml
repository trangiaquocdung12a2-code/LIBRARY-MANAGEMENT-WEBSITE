<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Library Management</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("Library Management", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })

            <button type="button" class="navbar-toggler" data-toggle="collapse" data-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Books", "Index", "Book", null, new { @class = "nav-link" })
                    </li>

                    @* CHANGED FROM "LibrarianDashboard" TO "Dashboard" TO MATCH YOUR CONTROLLER NAME *@
                    @if (Session["UserId"] != null && Session["Role"] != null && Session["Role"].ToString() == "Librarian")
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Dashboard", "Index", "Librarian", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (Session["UserId"] != null)
                    {
                        <li class="nav-item">
                            <a href="#" class="nav-link" style="pointer-events: none; color: #fff !important; font-weight: bold;">Hello, @Session["FullName"]</a>
                        </li>

                        if (Session["Role"] != null && Session["Role"].ToString() == "Librarian")
                        {
                            @* LIBRARIAN PROFILE - NOW AN ACTIVE WORKING LINK *@
                            <li class="nav-item">
                                @Html.ActionLink("Librarian Profile", "Profile", "Librarian", null, new { @class = "nav-link" })
                            </li>
                        }
                        else
                        {
                            @* REGULAR READER / STUDENT LINKS *@
                            <li class="nav-item">
                                @Html.ActionLink("My Profile", "Profile", "Reader", null, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("My Borrowings", "MyBorrowings", "Borrowing", null, new { @class = "nav-link" })
                            </li>
                        }

                        <li class="nav-item">
                            @Html.ActionLink("Logout", "Logout", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Login", "Login", "Account", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Register", "Register", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content" style="margin-top: 25px;">
        @RenderBody()

        <hr />

        <footer>
            <p>&copy; @DateTime.Now.Year - Library Management Website</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>