@model IEnumerable<LIBRARY_MANAGEMENT_WEBSITE.Models.Book>

@{
    ViewBag.Title = "Manage Books";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Fixed-size wrapper container configuration */
    .table-fixed-container {
        height: 550px;
        overflow-y: auto;
        border: 1px solid #e3e6f0;
        border-radius: 4px;
        box-shadow: inset 0 1px 3px rgba(0,0,0,0.05);
        background: #fff;
    }

        /* Make headers stick to top when scrolling down */
        .table-fixed-container table thead th {
            position: sticky;
            top: 0;
            background-color: #f8f9fc;
            z-index: 2;
            border-bottom: 2px solid #e3e6f0;
        }

    .page-title {
        font-weight: 700;
        color: #333;
        margin-top: 20px;
        margin-bottom: 5px;
    }
</style>

<div class="container" style="margin-top: 20px;">
    <h2 class="page-title">Books Manager</h2>

    <div style="margin-bottom: 20px;">
        <a href="@Url.Action("AddBook", "Admin")" class="btn btn-success" style="background-color: #198754; border-color: #198754; font-weight: 600; padding: 8px 16px;">
            <i class="glyphicon glyphicon-plus"></i> Add New Book
        </a>
    </div>

    <div class="table-fixed-container">
        <table class="table table-striped table-hover" style="margin-bottom: 0; vertical-align: middle;">
            <thead>
                <tr>
                    <th style="width: 15%;">ISBN</th>
                    <th style="width: 35%;">Title</th>
                    <th style="width: 15%;">Shelf</th>
                    <th style="width: 15%;">Available Copies</th>
                    <th style="width: 20%; text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var book in Model)
                    {
                        <tr>
                            <td style="font-family: monospace; font-weight: bold; color: #555;">
                                @(!string.IsNullOrEmpty(book.ISBN) ? book.ISBN : "N/A")
                            </td>
                            <td style="font-weight: 600; color: #222;">@book.Title</td>
                            <td>
                                <span class="label label-info" style="font-size: 11px; padding: 4px 8px;">
                                    @(string.IsNullOrEmpty(book.ShelfLocation) ? "Unassigned" : book.ShelfLocation)
                                </span>
                            </td>
                            <td style="font-weight: bold; color: #333;">
                                @book.AvailableCopies / @book.TotalCopies
                            </td>
                            <td style="text-align: center;">
                                <div class="btn-group" role="group">
                                    <a href="@Url.Action("EditBook", "Admin", new { id = book.BookId })" class="btn btn-primary btn-sm" style="padding: 5px 14px; font-weight: 600;">
                                        Edit
                                    </a>
                                    <a href="@Url.Action("DeleteBook", "Admin", new { id = book.BookId })"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to completely delete this book along with its image records? This action cannot be undone.');">
                                        <i class="glyphicon glyphicon-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted" style="padding: 40px;">
                            No books found matching the catalog records.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible" role="alert" style="margin-top: 15px;">
        <button type="file" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <i class="glyphicon glyphicon-exclamation-sign"></i> @TempData["ErrorMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible" role="alert" style="margin-top: 15px;">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <i class="glyphicon glyphicon-ok-sign"></i> @TempData["SuccessMessage"]
    </div>
}