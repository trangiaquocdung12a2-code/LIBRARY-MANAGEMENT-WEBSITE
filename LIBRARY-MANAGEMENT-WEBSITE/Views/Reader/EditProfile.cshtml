@model LIBRARY_MANAGEMENT_WEBSITE.Models.Reader

@{
    ViewBag.Title = "Update Profile";
}

<h2>Update Profile</h2>

<div class="profile-box">
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" action="@Url.Action("EditProfile", "Reader")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-3">
                @if (Model.UserAccount != null && !string.IsNullOrEmpty(Model.UserAccount.AvatarUrl))
                {
                    <img src="@Model.UserAccount.AvatarUrl" id="profileImagePreview" class="profile-avatar" style="width:200px; height:200px; object-fit:cover; border-radius:50%;" />
                }
                else
                {
                    <img src="https://via.placeholder.com/200x200?text=Avatar" id="profileImagePreview" class="profile-avatar" style="width:200px; height:200px; object-fit:cover; border-radius:50%;" />
                }

                <div class="form-group mt-10">
                    <label>Upload Avatar</label>
                    <input type="file" id="avatarFileInput" name="avatar" class="form-control" accept="image/*" onchange="previewSelectedAvatar(this);" />
                </div>
            </div>

            <div class="col-md-9">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text"
                           name="fullName"
                           class="form-control"
                           value="@(Model.UserAccount != null ? Model.UserAccount.FullName : "")" />
                </div>

                <div class="form-group">
                    <label>Phone</label>
                    <input type="text"
                           name="phone"
                           class="form-control"
                           value="@(Model.UserAccount != null ? Model.UserAccount.Phone : "")" />
                </div>

                <div class="form-group">
                    <label>Address</label>
                    <textarea name="address" class="form-control" rows="3">@(Model.UserAccount != null ? Model.UserAccount.Address : "")</textarea>
                </div>

                <div class="form-group">
                    <label>Date of Birth</label>
                    <input type="date"
                           name="dateOfBirth"
                           class="form-control"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")"
                           onkeydown="return false;"
                           value="@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("yyyy-MM-dd") : "")" />
                </div>

                <div class="form-group">
                    <label>Gender</label>
                    <select name="gender" class="form-control">
                        <option value="">-- Select Gender --</option>
                        <option value="Male" @(Model.Gender == "Male" ? "selected" : "")>Male</option>
                        <option value="Female" @(Model.Gender == "Female" ? "selected" : "")>Female</option>
                        <option value="Other" @(Model.Gender == "Other" ? "selected" : "")>Other</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">
                    Save Changes
                </button>

                <a href="@Url.Action("Profile", "Reader")" class="btn btn-default">
                    Back to Profile
                </a>
            </div>
        </div>
    </form>
</div>

<script type="text/javascript">
    function previewSelectedAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                // Dynamically sets the <img> src attribute directly to the selected image's binary stream base64 cache data
                document.getElementById('profileImagePreview').setAttribute('src', e.target.result);
            }

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>