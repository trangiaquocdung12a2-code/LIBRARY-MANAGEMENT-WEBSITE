@model IEnumerable<LIBRARY_MANAGEMENT_WEBSITE.Models.Fine>

@{
    ViewBag.Title = "Fine Accounting Ledgers";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var overdueBorrowings = ViewBag.OverdueBorrowings as List<LIBRARY_MANAGEMENT_WEBSITE.Models.Borrowing>;
}

<div class="container" style="margin-top: 30px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 style="font-weight:600; margin:0;"><i class="glyphicon glyphicon-usd"></i> 6/ Manage Fine Records Account Book</h2>
        <div>
            <a href="@Url.Action("Index", "Librarian")" class="btn btn-default"><i class="glyphicon glyphicon-arrow-left"></i> Dashboard</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="panel panel-danger" style="border-radius: 8px; overflow: hidden; margin-bottom: 40px;">
        <div class="panel-heading" style="background-color: #d9534f; color: white; font-weight: bold;">
            <i class="glyphicon glyphicon-exclamation-sign"></i> Active Unresolved Overdue Items (Requires Fine Issuance)
        </div>

        <div style="max-height: 350px; overflow-y: auto; overflow-x: auto;">
            <table class="table table-striped table-hover" style="margin-bottom:0; width:100%;">
                <thead style="position: sticky; top: 0; background: #fdf3f2; z-index: 10; box-shadow: 0 1px 0 rgba(0,0,0,0.1);">
                    <tr>
                        <th>Borrow ID</th>
                        <th>Reader Profile</th>
                        <th>Book Title Asset</th>
                        <th>Due Date Target</th>
                        <th>Days Overdue</th>
                        <th class="text-center">Action Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (overdueBorrowings != null && overdueBorrowings.Any())
                    {
                        foreach (var b in overdueBorrowings)
                        {
                            var detail = b.BorrowingDetails.FirstOrDefault();
                            int daysOverdue = (DateTime.Today - b.DueDate).Days;

                            // SYSTEM CALCULATED RULE: 1$ per day, capped explicitly at 500 max
                            decimal fineCharge = daysOverdue * 1.00m;
                            if (daysOverdue > 500)
                            {
                                fineCharge = 500.00m;
                            }

                            <tr>
                                <td><strong>#@b.BorrowingId</strong></td>
                                <td>
                                    <strong>@(b.Reader?.UserAccount?.FullName ?? "Unknown Profile")</strong><br />
                                    <small class="text-muted">Code: @(b.Reader != null ? b.Reader.ReaderCode : "N/A")</small>
                                </td>
                                <td>@(detail != null ? detail.Book?.Title : "System Catalog Asset")</td>
                                <td class="text-danger"><strong>@b.DueDate.ToString("yyyy-MM-dd")</strong></td>
                                <td>
                                    <span class="label label-danger">@daysOverdue Days Overdue</span>
                                </td>
                                <td class="text-center" style="vertical-align: middle;">
                                    <button type="button" class="btn btn-xs btn-danger" data-toggle="modal" data-target="#issueFineModal_@b.BorrowingId">
                                        <i class="glyphicon glyphicon-plus"></i> Issue Fine Penalty
                                    </button>

                                    <div class="modal fade" id="issueFineModal_@b.BorrowingId" tabindex="-1" role="dialog" aria-labelledby="issueFineLabel_@b.BorrowingId">
                                        <div class="modal-dialog text-left" role="document">
                                            <div class="modal-content" style="color: #333;">
                                                @using (Html.BeginForm("AddFine", "Librarian", FormMethod.Post))
                                                {
                                                    <input type="hidden" name="borrowingId" value="@b.BorrowingId" />
                                                    <input type="hidden" name="readerId" value="@b.ReaderId" />
                                                    <input type="hidden" name="amount" value="@fineCharge.ToString("F2")" />

                                                    <div class="modal-header bg-danger" style="background-color: #d9534f; color: white;">
                                                        <button type="button" class="close" data-dismiss="modal" style="color:white; opacity:1;">&times;</button>
                                                        <h4 class="modal-title" id="issueFineLabel_@b.BorrowingId" style="font-weight:600;margin:0;">Assess Fine Penalty: Borrowing #@b.BorrowingId</h4>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="alert alert-warning">
                                                            <strong>Account Target:</strong> @(b.Reader?.UserAccount?.FullName) (<small>@(b.Reader != null ? b.Reader.ReaderCode : "")</small>)<br />
                                                            <strong>Asset Overdue:</strong> @(detail != null ? detail.Book?.Title : "Catalog Book Link")
                                                        </div>
                                                        <div class="form-group">
                                                            <label>Violation Fine Type Code Classification:</label>
                                                            <select name="fineType" class="form-control">
                                                                <option value="Overdue">Overdue Fine Penalty</option>
                                                                <option value="Damaged">Damaged Asset Penalty</option>
                                                                <option value="Lost">Lost Catalog Item Settlement</option>
                                                            </select>
                                                        </div>

                                                        <div class="form-group">
                                                            <label>Assessment Monetary Penalty Value Amount ($):</label>
                                                            <div class="well well-sm" style="background-color: #f8f9fa; border-left: 5px solid #d9534f; margin-bottom: 5px;">
                                                                <span style="font-size: 1.5em; font-weight: bold; color: #d9534f;">$@fineCharge.ToString("N2")</span>
                                                            </div>
                                                            <small class="text-muted" style="display: block; margin-top: 5px;">
                                                                Calculated metric: <strong>@daysOverdue days late</strong> &times; $1.00/day (Capped maximum of $500.00). This value is locked by system logic guidelines.
                                                            </small>
                                                        </div>

                                                        <div class="form-group">
                                                            <label>Administrative Notes Narrative:</label>
                                                            <textarea name="notes" class="form-control" rows="3" placeholder="Provide notes..." required>Automated fine processing trigger. Item tracking marks it at @daysOverdue days late.</textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-default" data-dismiss="modal">Dismiss</button>
                                                        <button type="submit" class="btn btn-danger">Post Fine Assessment Record</button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted" style="padding: 20px;">No current active transactions are past their return target due date. Excellent condition!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="panel panel-default" style="border-radius: 8px; overflow: hidden;">
        <div class="panel-heading" style="font-weight: bold; background: #f8f9fa;">
            <i class="glyphicon glyphicon-list-alt"></i> Historical Fine Penalty Ledgers Account Logs
        </div>

        <div style="max-height: 450px; overflow-y: auto; overflow-x: auto;">
            <table class="table table-striped table-hover" style="margin-bottom:0; width:100%;">
                <thead style="position: sticky; top: 0; background: #f8f9fa; z-index: 10; box-shadow: 0 1px 0 rgba(0,0,0,0.1);">
                    <tr>
                        <th>Fine ID</th>
                        <th>Reader Profile Target</th>
                        <th>Fine Type / Context</th>
                        <th>Fee Amount</th>
                        <th>Payment Status</th>
                        <th>Issued Date Log</th>
                        <th class="text-center">Action Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fine in Model)
                    {
                        <tr>
                            <td><strong>#@fine.FineId</strong></td>
                            <td>
                                <strong>@(fine.Reader?.UserAccount?.FullName ?? "Unknown Profile")</strong><br />
                                <small class="text-muted">Code: @(fine.Reader != null ? fine.Reader.ReaderCode : "N/A")</small>
                            </td>
                            <td>
                                <span class="label @(fine.FineType == "Overdue" ? "label-warning" : fine.FineType == "Damaged" ? "label-info" : "label-danger")">@fine.FineType</span>
                                <div style="font-size:0.85em; margin-top:4px; max-width: 320px; word-wrap: break-word;" class="text-muted">@fine.Notes</div>
                            </td>
                            <td><strong>$@fine.Amount.ToString("N2")</strong></td>
                            <td>
                                <span class="label @(fine.PaymentStatus == "Paid" ? "label-success" : "label-danger")">@fine.PaymentStatus</span>
                                @if (fine.PaymentStatus == "Paid")
                                {
                                    <div style="font-size:0.75em; margin-top:2px;" class="text-muted">Via @fine.PaymentMethod</div>
                                }
                            </td>
                            <td>@fine.IssuedDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-center" style="vertical-align: middle;">
                                @if (fine.PaymentStatus == "Unpaid")
                                {
                                    <button type="button" class="btn btn-sm btn-success" data-toggle="modal" data-target="#payModal_@fine.FineId">
                                        <span class="glyphicon glyphicon-usd"></span> Confirm Payment
                                    </button>

                                    <div class="modal fade" id="payModal_@fine.FineId" tabindex="-1" role="dialog" aria-labelledby="payModalLabel_@fine.FineId">
                                        <div class="modal-dialog text-left" role="document">
                                            <div class="modal-content" style="color:#333;">
                                                <div class="modal-header bg-success" style="background-color: #28a745; color: white;">
                                                    <button type="button" class="close" data-dismiss="modal" style="color:white; opacity:1;">&times;</button>
                                                    <h4 class="modal-title" id="payModalLabel_@fine.FineId" style="font-weight:700; margin:0;">Process Payment Verification for Fine Record #@fine.FineId</h4>
                                                </div>

                                                @using (Html.BeginForm("ProcessPayment", "Librarian", FormMethod.Post, new { enctype = "multipart/form-data" }))
                                                {
                                                    <div class="modal-body" style="padding: 20px;">
                                                        <input type="hidden" name="FineId" value="@fine.FineId" />

                                                        <div class="alert alert-info" style="margin-bottom: 20px;">
                                                            <strong>Target Account File:</strong> @(fine.Reader?.UserAccount?.FullName ?? "N/A") (<small>@(fine.Reader != null ? fine.Reader.ReaderCode : "")</small>)<br />
                                                            <strong>Outstanding Penalty Charge Balance:</strong> <span class="text-danger font-weight-bold" style="font-size:1.1em;">$@fine.Amount.ToString("N2")</span>
                                                        </div>

                                                        <div class="form-group">
                                                            <label class="control-label">Select Payment Method Designation:</label>
                                                            <select name="PaymentMethod" class="form-control" required>
                                                                <option value="Cash">Cash Currency Hand-over</option>
                                                                <option value="VNPay">VNPay Gateway Interface</option>
                                                                <option value="PayPal">PayPal Wire Routing</option>
                                                                <option value="Bank Transfer">Direct Bank Account Clearing</option>
                                                            </select>
                                                        </div>

                                                        <div class="form-group" style="margin-top: 15px;">
                                                            <label class="control-label">Upload Transaction Receipt Image File Proof:</label>
                                                            <input type="file" name="TransactionReceiptFile" class="form-control" accept="image/*" required />
                                                            <small class="text-muted" style="display:block; margin-top:4px;">Accepted formats: .jpg, .jpeg, .png.</small>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-success" style="background-color: #28a745; border-color: #28a745;">Finalize & Clear Fine Balance</button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-success glyphicon glyphicon-ok-sign" style="font-size: 1.25em;" title="Account Settled Successfully"></span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section scripts {
    <script src="https://code.jquery.com/jquery-1.12.4.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            console.log("jQuery and Bootstrap scripts successfully verified!");

            // 2. Keep the hard-trigger helper so your buttons always match up to their modals
            $('[data-toggle="modal"]').click(function () {
                var targetModal = $(this).attr('data-target');
                $(targetModal).modal('show');
            });

            // 3. Keep the cleanup script to fix the unclickable screen freeze on cancel
            $(document).on('hidden.bs.modal', '.modal', function () {
                // Force remove any leftover backdrop overlays blocking mouse events
                $('.modal-backdrop').remove();
                // Restore regular mouse scrolling to the master view window
                $('body').removeClass('modal-open').css('padding-right', '');
            });
        });
    </script>
}