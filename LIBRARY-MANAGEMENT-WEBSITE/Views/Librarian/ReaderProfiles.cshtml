@model IEnumerable<LIBRARY_MANAGEMENT_WEBSITE.Models.Reader>

@{
    ViewBag.Title = "Reader Profiles Management";
}

<div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 20px;">
    <h2>Reader Profiles Matrix</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm" style="border-radius: 8px; overflow: hidden;">
    <div class="card-body p-0" style="max-height: 500px; overflow-y: auto; background: #fff;">
        <table class="table table-hover table-striped mb-0" style="vertical-align: middle;">
            <thead class="thead-dark bg-dark text-white" style="position: sticky; top: 0; z-index: 10; box-shadow: 0 1px 0 #343a40;">
                <tr>
                    <th style="padding: 12px; border-top: none;">Reader Code</th>
                    <th style="border-top: none;">Full Name</th>
                    <th style="border-top: none;">Email Address</th>
                    <th style="border-top: none;">Phone</th>
                    <th style="border-top: none;">Gender</th>
                    <th style="border-top: none;" class="text-center">Total Borrowed</th>
                    <th style="border-top: none;">Outstanding Fines</th>
                    <th style="border-top: none;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var reader in Model)
                    {
                        <tr>
                            <td style="padding: 12px; font-weight: bold; vertical-align: middle;">
                                <code style="font-size: 0.95rem;">@reader.ReaderCode</code>
                            </td>
                            <td style="vertical-align: middle;">
                                @(reader.UserAccount != null ? reader.UserAccount.FullName : "N/A")
                            </td>
                            <td style="vertical-align: middle;">
                                @(reader.UserAccount != null ? reader.UserAccount.Email : "N/A")
                            </td>
                            <td style="vertical-align: middle;">
                                @(reader.UserAccount != null ? reader.UserAccount.Phone : "N/A")
                            </td>
                            <td style="vertical-align: middle;">@reader.Gender</td>
                            <td style="vertical-align: middle;" class="text-center">
                                <span class="badge bg-secondary">@reader.TotalBorrowed</span>
                            </td>
                            <td style="vertical-align: middle;">
                                @if (reader.TotalFines > 0)
                                {
                                    <span class="text-danger font-weight-bold">@reader.TotalFines.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-success">No outstanding fines</span>
                                }
                            </td>
                            <td class="text-center" style="vertical-align: middle; white-space: nowrap;">
                                <a href="@Url.Action("ReaderDetails", "Librarian", new { id = reader.ReaderId })" class="btn btn-sm btn-info text-white">
                                    <i class="glyphicon glyphicon-eye-open"></i> View Full Details / History
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted" style="padding: 30px;">
                            <i class="glyphicon glyphicon-info-sign" style="font-size: 1.5em; display: block; margin-bottom: 8px;"></i>
                            No registered readers are currently available in the database system.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index", "Librarian")" class="btn btn-default">
        <span class="glyphicon glyphicon-arrow-left"></span> Back to Dashboard
    </a>
</div>