@model IEnumerable<LIBRARY_MANAGEMENT_WEBSITE.Controllers.BorrowRequestViewModel>

@{
    ViewBag.Title = "Manage Borrowing Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Filter into two operational categories
    var activeRequests = Model.Where(m => m.Status == "Pending" || m.Status == "Approved" || m.Status == "Overdue").ToList();
    var concludedRequests = Model.Where(m => m.Status == "Returned" || m.Status == "Rejected").ToList();
}

<div class="container" style="margin-top: 30px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 style="font-weight:600; margin:0;"><i class="glyphicon glyphicon-transfer"></i> Manage Requests & Approvals</h2>
        <a href="@Url.Action("Index", "Librarian")" class="btn btn-default"><i class="glyphicon glyphicon-arrow-left"></i> Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="panel panel-warning" style="border-radius: 8px; overflow: hidden; margin-bottom: 35px; border-color: #f0ad4e;">
        <div class="panel-heading" style="background-color: #fcf8e3; border-color: #f0ad4e; color: #8a6d3b; font-weight: 700; font-size: 1.1em;">
            <i class="glyphicon glyphicon-time"></i> 1. Active Action Requests Queue (@activeRequests.Count)
        </div>

        <div style="max-height: 400px; overflow-y: auto; background: #fff;">
            @if (!activeRequests.Any())
            {
                <div style="padding: 30px; text-align: center; color: #777;">
                    <i class="glyphicon glyphicon-ok-circle" style="font-size: 2em; color: #5cb85c; display: block; margin-bottom: 10px;"></i>
                    No active requests require processing at this time.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover" style="margin-bottom: 0; vertical-align: middle;">
                        <thead style="background: #f8f9fa; position: sticky; top: 0; z-index: 10; box-shadow: 0 1px 0 #ddd;">
                            <tr>
                                <th style="width: 12%;">Transaction ID</th>
                                <th style="width: 25%;">Reader Profile</th>
                                <th style="width: 25%;">Target Book Asset</th>
                                <th style="width: 18%;">Duration Window</th>
                                <th style="width: 10%;">Current Status</th>
                                <th style="width: 10%;" class="text-right">Execution Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in activeRequests)
                            {
                                <tr>
                                    <td style="vertical-align: middle;"><strong>BRW-#@item.BorrowingId</strong></td>
                                    <td style="vertical-align: middle;">
                                        <div><strong>@item.ReaderName</strong></div>
                                        <small class="text-muted">Code: @item.ReaderCode | Email: @item.ReaderEmail</small>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <div>@item.BookTitle</div>
                                        <small class="text-muted">ISBN: @item.BookISBN | Available: @item.AvailableCopies</small>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <div><small><strong>Borrow:</strong> @item.BorrowDateText</small></div>
                                        <div><small><strong>Due Date:</strong> @item.DueDateText</small></div>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <span class="label @(item.Status == "Approved" ? "label-info" : item.Status == "Pending" ? "label-warning" : "label-danger")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-right" style="vertical-align: middle; white-space: nowrap;">
                                        @if (item.Status == "Pending")
                                        {
                                            using (Html.BeginForm("ProcessRequest", "Librarian", FormMethod.Post, new { style = "display:inline-block;" }))
                                            {
                                                <input type="hidden" name="borrowingId" value="@item.BorrowingId" />
                                                <button type="submit" name="decision" value="Approve" class="btn btn-xs btn-success" style="margin-right: 2px;"><i class="glyphicon glyphicon-ok"></i> Approve</button>
                                                <button type="submit" name="decision" value="Reject" class="btn btn-xs btn-danger"><i class="glyphicon glyphicon-remove"></i> Reject</button>
                                            }
                                        }
                                        else if (item.Status == "Approved" || item.Status == "Overdue")
                                        {
                                            using (Html.BeginForm("ProcessRequest", "Librarian", FormMethod.Post, new { style = "display:inline-block;" }))
                                            {
                                                <input type="hidden" name="borrowingId" value="@item.BorrowingId" />
                                                <button type="submit" name="decision" value="Return" class="btn btn-xs btn-primary"><i class="glyphicon glyphicon-import"></i> Process Return</button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="panel panel-default" style="border-radius: 8px; overflow: hidden; border-color: #ddd;">
        <div class="panel-heading" style="background-color: #f5f5f5; border-color: #ddd; color: #333; font-weight: 700; font-size: 1.1em;">
            <i class="glyphicon glyphicon-folder-close"></i> 2. Concluded Lifecycle History Logs (@concludedRequests.Count)
        </div>

        <div style="max-height: 400px; overflow-y: auto; background: #fff;">
            @if (!concludedRequests.Any())
            {
                <div style="padding: 30px; text-align: center; color: #777;">
                    No archive history log sheets built yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover" style="margin-bottom: 0; vertical-align: middle;">
                        <thead style="background: #f8f9fa; position: sticky; top: 0; z-index: 10; box-shadow: 0 1px 0 #ddd;">
                            <tr>
                                <th style="width: 12%;">Transaction ID</th>
                                <th style="width: 25%;">Reader Profile</th>
                                <th style="width: 25%;">Target Book Asset</th>
                                <th style="width: 18%;">Duration Window</th>
                                <th style="width: 10%;">Current Status</th>
                                <th style="width: 10%;" class="text-right">Execution Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in concludedRequests)
                            {
                                <tr>
                                    <td style="vertical-align: middle;"><strong>BRW-#@item.BorrowingId</strong></td>
                                    <td style="vertical-align: middle;">
                                        <div><strong>@item.ReaderName</strong></div>
                                        <small class="text-muted">Code: @item.ReaderCode | Email: @item.ReaderEmail</small>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <div>@item.BookTitle</div>
                                        <small class="text-muted">ISBN: @item.BookISBN</small>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <div><small><strong>Borrow:</strong> @item.BorrowDateText</small></div>
                                        <div><small><strong>Due Date:</strong> @item.DueDateText</small></div>
                                    </td>
                                    <td style="vertical-align: middle;">
                                        <span class="label @(item.Status == "Returned" ? "label-success" : "label-danger")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-right" style="vertical-align: middle;">
                                        <span class="text-muted" style="font-size:0.9em; font-weight: 600; font-style: italic;">
                                            <i class="glyphicon glyphicon-lock"></i> Book Returned
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>