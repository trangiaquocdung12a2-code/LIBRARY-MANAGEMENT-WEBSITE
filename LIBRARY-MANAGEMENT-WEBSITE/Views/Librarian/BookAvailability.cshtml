@model IEnumerable<LIBRARY_MANAGEMENT_WEBSITE.Models.Book>

@{
    ViewBag.Title = "Manage Book Availability Statuses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid" style="margin-top: 30px; max-width: 1400px; padding-left: 15px; padding-right: 15px;">

    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 10px;">
        <h2 style="font-weight:600; margin:0; font-size: calc(1.3rem + 0.6vw);"><i class="glyphicon glyphicon-book"></i> 4/ Manage Book Availability Statuses</h2>
        <div>
            <a href="@Url.Action("Index", "Librarian")" class="btn btn-default"><i class="glyphicon glyphicon-arrow-left"></i> Dashboard</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="panel panel-default" style="border-radius: 8px; overflow: hidden; margin-bottom: 30px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        <div style="width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <table class="table table-striped table-hover" style="margin-bottom:0; min-width: 900px; vertical-align: middle;">
                <thead style="background: #f8f9fa;">
                    <tr>
                        <th style="width: 30%;">Book Information</th>
                        <th style="width: 15%;">Category</th>
                        <th style="width: 12%;">Total Stock</th>
                        <th style="width: 12%;">Available Stock</th>
                        <th style="width: 16%;">Status Evaluation</th>
                        <th style="width: 15%;" class="text-center">Declare Status Drop</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td style="vertical-align: middle; white-space: normal;">
                                <strong style="font-size: 1.05em; color: #111; display: block; margin-bottom: 2px;">@book.Title</strong>
                                <small class="text-muted" style="display: block; line-height: 1.4;">By @(book.Author?.FullName ?? "Unknown Author") | ISBN: @book.ISBN</small>
                            </td>
                            <td style="vertical-align: middle;">
                                <span class="label label-default" style="font-size: 0.9em; background-color: #f0f1f2; color: #333; border: 1px solid #ddd;">
                                    @(book.Category != null ? book.Category.CategoryName : "Unassigned")
                                </span>
                            </td>

                            <td style="vertical-align: middle; color: #000000; font-weight: 700; font-size: 1.05em;">
                                @book.TotalCopies <span style="font-weight: normal; font-size: 0.9em; color: #333;">Total</span>
                            </td>
                            <td style="vertical-align: middle; color: #000000; font-weight: 800; font-size: 1.05em;">
                                @book.AvailableCopies <span style="font-weight: normal; font-size: 0.9em; color: #333;">Available</span>
                            </td>

                            <td style="vertical-align: middle;">
                                @if (book.AvailableCopies > 0)
                                {
                                    <span class="text-success" style="font-weight: 700; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="glyphicon glyphicon-ok-sign"></i> Available on Shelf
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger" style="font-weight: 700; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="glyphicon glyphicon-remove-sign"></i> Out of Stock
                                    </span>
                                }
                            </td>
                            <td class="text-center" style="vertical-align: middle;">
                                <button type="button" class="btn btn-sm btn-danger" data-toggle="modal" data-target="#reportIncidentModal_@book.BookId" style="font-weight: 600;">
                                    <i class="glyphicon glyphicon-flag"></i> Report Copy Status
                                </button>

                                <div class="modal fade" id="reportIncidentModal_@book.BookId" tabindex="-1" role="dialog" aria-labelledby="incidentLabel_@book.BookId">
                                    <div class="modal-dialog text-left" role="document">
                                        <div class="modal-content" style="color: #333; border-radius: 6px;">
                                            @using (Html.BeginForm("ReportBookIncident", "Librarian", FormMethod.Post))
                                            {
                                                <input type="hidden" name="bookId" value="@book.BookId" />

                                                <div class="modal-header" style="background-color: #d9534f; color: white; border-top-left-radius: 5px; border-top-right-radius: 5px;">
                                                    <button type="button" class="close" data-dismiss="modal" style="color:white; opacity:1;">&times;</button>
                                                    <h4 class="modal-title" id="incidentLabel_@book.BookId" style="font-weight:600; margin:0;">Declare Catalog Incident Record</h4>
                                                </div>
                                                <div class="modal-body" style="padding: 20px;">
                                                    <div class="alert alert-warning" style="margin-bottom: 20px; border-left: 4px solid #f0ad4e;">
                                                        <strong style="display:block; margin-bottom: 4px; color: #8a6d3b;">Selected Asset:</strong>
                                                        <span style="font-size: 1.1em; font-weight:700; color: #333;">@book.Title</span>
                                                    </div>

                                                    <div class="form-group">
                                                        <label class="control-label" style="font-weight: 600; margin-bottom: 6px;">Select Book Condition/Incident Cause:</label>
                                                        <select name="incidentType" class="form-control" style="height: 40px;" required>
                                                            <option value="Damaged by Reader">Damaged by Reader Profile</option>
                                                            <option value="Missing / Lost">Missing or Misplaced Item Copy</option>
                                                            <option value="Worn Out / Destroyed">Worn Down Beyond Usability Guidelines</option>
                                                            <option value="Stolen">Stolen / Non-Returned Counter Check</option>
                                                        </select>
                                                    </div>

                                                    <div class="form-group" style="margin-top: 15px;">
                                                        <label class="control-label" style="font-weight: 600; margin-bottom: 6px;">Administrative Log Entry Notes:</label>
                                                        <textarea name="internalNotes" class="form-control" rows="3" placeholder="Provide description notes regarding copy damage details or audit verification trace indicators..." required></textarea>
                                                    </div>

                                                    <p class="text-danger" style="margin-top:15px; font-size: 0.9em; font-weight: 600;">
                                                        <i class="glyphicon glyphicon-warning-sign"></i> Warning: Submitting updates will deduct 1 available unit copy instantly.
                                                    </p>
                                                </div>
                                                <div class="modal-footer" style="background: #f8f9fa; border-top: 1px solid #eee;">
                                                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel Action</button>
                                                    <button type="submit" class="btn btn-danger" style="font-weight:600;">Submit & Process Inventory Drop</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-1.12.4.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            // 2. Explicit button trigger fallback to open the target modal safely
            $('[data-toggle="modal"]').click(function (e) {
                e.preventDefault();
                var targetModal = $(this).attr('data-target');
                $(targetModal).modal('show');
            });

            // 3. Cleanup handler to prevent screen-freeze overlay bugs when dismissed
            $(document).on('hidden.bs.modal', '.modal', function () {
                // Force remove any leftover backdrop overlays blocking mouse events
                $('.modal-backdrop').remove();
                // Restore regular mouse scrolling to the master view window
                $('body').removeClass('modal-open').css('padding-right', '');
            });
        });
    </script>
}
